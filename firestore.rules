rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // YORDAMCHI FUNKSIYA
    // ==========================================
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // FOYDALANUVCHILAR + BARCHA SUBCOLLECTION LAR
    // match /users/{userId}  faqat document ni yopar
    // {document=**} esa BARCHA ichki collectionlarni yopadi
    // ==========================================
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow delete: if false;

      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Chuqur subcollection lar uchun (chats/messages kabi)
      match /{path=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ==========================================
    // VAULT
    // ==========================================
    match /vault_files/{userId}/{fileId} {
      allow read, write: if isOwner(userId);
    }

    // ==========================================
    // EXAMER
    // ==========================================
    match /exams/{userId}/{examId} {
      allow read, write: if isOwner(userId);
    }
    match /exam_results/{userId}/{resultId} {
      allow read, write: if isOwner(userId);
    }

    // ==========================================
    // TYPING LEADERBOARD — faqat o'qish hammaga
    // ==========================================
    match /typing_leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // ==========================================
    // SYSTEM CONFIG — faqat admin yozadi
    // ==========================================
    match /system/{configId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /admin_config/{configId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ==========================================
    // DEFAULT — boshqa HAMMA NARSA BLOKLANGAN
    // Hacker apiKey ni bilsa ham bu qoida ishga tushadi
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
