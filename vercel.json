{
    "buildCommand": "npm run build",
    "outputDirectory": ".",
    "framework": null,
    "routes": [
        {
            "src": "/env\\.js",
            "status": 404,
            "dest": "/404.html"
        },
        {
            "src": "/build\\.js",
            "status": 404,
            "dest": "/404.html"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
