{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    
    "system": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    }
  }
}