{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "system": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
